---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
}

const {
  eyebrow = 'About',
  title = 'Section placeholder for future content',
  description = 'This component is ready for CMS or API-driven content later without changing the page shell.',
} = Astro.props as Props;
---

<section class="container mx-auto px-6 py-16 md:py-24 relative z-10">
  <div class="max-w-3xl">
    <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">{eyebrow}</p>
    <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">{title}</h2>
    <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">{description}</p>
    <slot />
  </div>
</section>