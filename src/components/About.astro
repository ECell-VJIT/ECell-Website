---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  vision?: string;
  mission?: string;
  closing?: string;
}

const {
  eyebrow = 'About E-Cell VJIT',
  title = 'Building a culture of innovation, leadership, and startup thinking',
  description = 'The Entrepreneurship Cell (E-Cell) at VJIT is a student-led platform committed to nurturing innovation and entrepreneurial thinking, enabling the transformation of ideas into meaningful, real-world ventures.',
  vision = 'To cultivate a dynamic culture of innovation and entrepreneurship, empowering students to evolve into visionary leaders and job creators who drive meaningful impact in a sustainable, technology-driven future.',
  mission = 'To equip students through hands-on hackathons, workshops, and startup programs that bridge the gap between ideas and real-world experience, while fostering a supportive ecosystem of mentorship and industry networking to enable the development, testing, and scaling of innovative ventures.',
  closing = 'Through workshops, mentorship programs, startup bootcamps, and flagship events like PitchQuest and E-Conclave, we bridge the gap between academic learning and entrepreneurship - empowering students to think boldly, build fearlessly, and lead with impact.',
} = Astro.props as Props;
---

<section id="about" class="container mx-auto px-6 py-16 md:py-24 relative z-10">
  <div class="max-w-5xl">
    <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">{eyebrow}</p>
    <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">{title}</h2>
    <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">{description}</p>
    <div class="grid gap-5 md:grid-cols-2 mt-8">
      <article class="glass rounded-2xl p-6 border border-red-500/15">
        <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-3">Vision</p>
        <p class="text-gray-200 font-inter leading-relaxed">{vision}</p>
      </article>
      <article class="glass rounded-2xl p-6 border border-red-500/15">
        <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-3">Mission</p>
        <p class="text-gray-200 font-inter leading-relaxed">{mission}</p>
      </article>
    </div>
    <p class="mt-8 text-gray-300 font-inter text-base md:text-lg leading-relaxed">{closing}</p>
    <slot />
  </div>
</section>