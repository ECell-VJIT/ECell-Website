---
interface Props {
  brand?: string;
  copyright?: string;
}

const {
  brand = 'E-Cell VJIT',
  copyright = String(new Date().getFullYear()),
} = Astro.props as Props;

const footerLinks = [
  {
    title: 'About',
    links: [
      { label: 'Mission', href: '/#about' },
      { label: 'What We Do', href: '/#domains' },
      { label: 'Core Team', href: '/team' }
    ]
  },
  {
    title: 'Explore',
    links: [
      { label: 'Events', href: '/events' },
      { label: 'Join', href: '/#join' },
      { label: 'Team Directory', href: '/team' }
    ]
  }
];

const contactInfo = [
  {
    icon: 'solar:letter-linear',
    text: 'hello@ecellvjit.in',
    href: 'mailto:hello@ecellvjit.in'
  },
  {
    icon: 'solar:phone-linear',
    text: '+91 90000 00000',
    href: 'tel:+919000000000'
  },
  {
    icon: 'solar:map-point-linear',
    text: 'VJIT Campus, Hyderabad'
  }
];

const socialLinks = [
  { icon: 'mdi:instagram', label: 'Instagram', href: '#' },
  { icon: 'mdi:linkedin', label: 'LinkedIn', href: '#' },
  { icon: 'mdi:github', label: 'GitHub', href: '#' }
];
---

<footer class="container mx-auto px-6 pt-8 pb-10 relative z-10 text-sm text-gray-300 font-inter">
  <div class="footer-shell noise-overlay rounded-3xl overflow-hidden relative">
    <div class="footer-bg" aria-hidden="true"></div>

    <div class="relative z-10 p-8 md:p-10 lg:p-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-8 lg:gap-12 pb-10">
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <span class="footer-brand-icon">
              <iconify-icon icon="solar:rocket-2-linear" width="20" height="20"></iconify-icon>
            </span>
            <span class="text-white text-2xl font-jakarta font-semibold tracking-tight">{brand}</span>
          </div>
          <p class="text-sm leading-relaxed text-gray-300 max-w-xs">
            Student innovation and entrepreneurship community focused on building ideas, startups, and leadership culture.
          </p>
        </div>

        {footerLinks.map((section) => (
          <div>
            <h4 class="text-white text-lg font-semibold mb-5 font-jakarta">{section.title}</h4>
            <ul class="space-y-3">
              {section.links.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <div>
          <h4 class="text-white text-lg font-semibold mb-5 font-jakarta">Contact</h4>
          <ul class="space-y-4">
            {contactInfo.map((item) => (
              <li class="flex items-center gap-3 text-gray-300">
                <span class="footer-contact-icon">
                  <iconify-icon icon={item.icon} width="18" height="18"></iconify-icon>
                </span>
                {item.href ? (
                  <a href={item.href} class="footer-link">{item.text}</a>
                ) : (
                  <span>{item.text}</span>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="text-white text-lg font-semibold mb-5 font-jakarta">Connect</h4>
          <div class="flex flex-wrap gap-3">
            {socialLinks.map(({ icon, label, href }) => (
              <a href={href} aria-label={label} class="footer-social-link">
                <iconify-icon icon={icon} width="19" height="19"></iconify-icon>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="fire-line-divider" aria-hidden="true"></div>

      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-center md:text-left text-gray-400">
          Copyright {copyright} {brand}. All rights reserved.
        </p>
        <span class="footer-badge">Built for student founders</span>
      </div>

      <div class="hidden lg:flex h-44 -mb-16 pointer-events-none select-none mt-6" data-footer-hover>
        <svg width="100%" height="100%" viewBox="0 0 1200 220" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
          <defs>
            <linearGradient id="footerTextGradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#fb7185" />
              <stop offset="50%" stop-color="#ef4444" />
              <stop offset="100%" stop-color="#fb923c" />
            </linearGradient>

            <radialGradient id="footerRevealMaskGradient" cx="50%" cy="50%" r="24%">
              <stop offset="0%" stop-color="white" />
              <stop offset="100%" stop-color="black" />
            </radialGradient>

            <mask id="footerTextMask">
              <rect x="0" y="0" width="1200" height="220" fill="url(#footerRevealMaskGradient)" />
            </mask>
          </defs>

          <text x="50%" y="56%" text-anchor="middle" dominant-baseline="middle" class="footer-hover-outline">E-CELL VJIT</text>
          <text x="50%" y="56%" text-anchor="middle" dominant-baseline="middle" class="footer-hover-stroke">E-CELL VJIT</text>
          <text x="50%" y="56%" text-anchor="middle" dominant-baseline="middle" stroke="url(#footerTextGradient)" mask="url(#footerTextMask)" class="footer-hover-reveal">E-CELL VJIT</text>
        </svg>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-footer-hover]');
    if (!(root instanceof HTMLElement)) return;

    const svg = root.querySelector('svg');
    const revealGradient = root.querySelector('#footerRevealMaskGradient');
    if (!(svg instanceof SVGSVGElement) || !(revealGradient instanceof SVGRadialGradientElement)) return;

    let targetX = 50;
    let targetY = 50;
    let currentX = 50;
    let currentY = 50;
    let ticking = false;

    const animate = () => {
      currentX += (targetX - currentX) * 0.16;
      currentY += (targetY - currentY) * 0.16;
      revealGradient.setAttribute('cx', `${currentX}%`);
      revealGradient.setAttribute('cy', `${currentY}%`);
      if (Math.abs(targetX - currentX) > 0.02 || Math.abs(targetY - currentY) > 0.02) {
        requestAnimationFrame(animate);
      } else {
        ticking = false;
      }
    };

    const queueAnimation = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(animate);
      }
    };

    const moveMask = (event) => {
      const rect = svg.getBoundingClientRect();
      targetX = ((event.clientX - rect.left) / rect.width) * 100;
      targetY = ((event.clientY - rect.top) / rect.height) * 100;
      queueAnimation();
    };

    root.addEventListener('mousemove', moveMask, { passive: true });
    root.addEventListener('mouseenter', queueAnimation, { passive: true });
    root.addEventListener('mouseleave', () => {
      targetX = 50;
      targetY = 50;
      queueAnimation();
    }, { passive: true });
  })();
</script>

<style>
  .footer-shell {
    border: 1px solid rgba(248, 113, 113, 0.18);
    background: linear-gradient(165deg, rgba(24, 5, 4, 0.9), rgba(12, 3, 2, 0.92));
  }

  .footer-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(125% 140% at 50% 0%, rgba(185, 28, 28, 0.22) 0%, rgba(17, 4, 3, 0.1) 55%, rgba(10, 3, 2, 0.7) 100%);
    pointer-events: none;
  }

  .footer-brand-icon {
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgb(254 202 202);
    border: 1px solid rgba(248, 113, 113, 0.38);
    background: linear-gradient(135deg, rgba(127, 29, 29, 0.45), rgba(17, 24, 39, 0.08));
  }

  .footer-link {
    color: rgb(209 213 219);
    transition: color 180ms ease;
  }

  .footer-link:hover {
    color: rgb(254 226 226);
  }

  .footer-contact-icon {
    color: rgb(252 165 165);
  }

  .footer-social-link {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgb(209 213 219);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.02);
    transition: transform 160ms ease, border-color 180ms ease, color 180ms ease;
  }

  .footer-social-link:hover {
    transform: translateY(-1px);
    color: rgb(254 226 226);
    border-color: rgba(248, 113, 113, 0.4);
  }

  .footer-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.45rem 0.75rem;
    font-size: 0.72rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: rgb(254 202 202);
    border: 1px solid rgba(248, 113, 113, 0.24);
    background: rgba(127, 29, 29, 0.18);
  }

  .footer-hover-outline,
  .footer-hover-stroke,
  .footer-hover-reveal {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 130px;
    font-weight: 700;
    fill: transparent;
    letter-spacing: 4px;
  }

  .footer-hover-outline {
    stroke: rgba(255, 226, 226, 0.24);
    stroke-width: 0.5;
  }

  .footer-hover-stroke {
    stroke: rgba(255, 120, 110, 0.92);
    stroke-width: 0.6;
    stroke-dasharray: 950;
    stroke-dashoffset: 950;
    animation: footerStrokeDraw 5s ease-in-out infinite alternate;
  }

  .footer-hover-reveal {
    stroke-width: 0.42;
  }

  @keyframes footerStrokeDraw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 768px) {
    .footer-shell {
      border-radius: 1.25rem;
    }
  }
</style>