---
interface Props {
  brand?: string;
  copyright?: string;
}

const {
  brand = 'Ignite',
  copyright = '2026',
} = Astro.props as Props;
---

<footer class="container mx-auto px-6 py-10 relative z-10 text-sm text-gray-400 font-inter">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 border-t border-white/10 pt-6">
    <p class="font-jakarta text-white text-base">{brand}</p>
    <p>Copyright {copyright}</p>
  </div>
</footer>