---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  navLinks?: NavLink[];
}

const { navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Opportunities', href: '#domains' },
  { label: 'Traction', href: '#traction' },
  { label: 'Team', href: '/team' },
  { label: 'Launch', href: '/events' },
] } = Astro.props as Props;
---

<nav class="container mx-auto px-6 py-6 relative z-10">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="text-red-500 flex items-center justify-center">
        <iconify-icon icon="solar:bonfire-linear" width="32" height="32" stroke-width="1.5"></iconify-icon>
      </div>
      <span class="text-xl font-jakarta font-semibold tracking-tight">E-Cell VJIT</span>
    </div>
    <div class="hidden md:flex space-x-10 text-base font-inter text-gray-300">
      {navLinks.map((link) => (
        <a href={link.href} class="hover:text-red-400 transition-colors">{link.label}</a>
      ))}
    </div>
    <div>
      <a href="/events" class="text-sm font-inter glass rounded-md px-4 py-2 hover:bg-red-900/20 hover:border-red-500/30 text-gray-200 transition-all flex items-center gap-2">
        <span>View Events</span>
        <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
      </a>
    </div>
  </div>
</nav>

<div class="h-px glass-divider relative z-10"></div>