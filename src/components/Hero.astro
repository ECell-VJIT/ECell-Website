---
interface Props {
  title?: string;
  description?: string;
  primaryAction?: string;
  secondaryAction?: string;
  primaryHref?: string;
  secondaryHref?: string;
}

const {
  title = 'E-CELL VJIT',
  description = 'E-Cell brings together students who want to learn, build, and experiment with real-world problems. Through events, mentorship, and a strong community, it creates opportunities to move from curiosity to execution.',
  primaryAction = 'View Upcoming Events',
  secondaryAction = 'Register for Events',
  primaryHref = '/events',
  secondaryHref = '/events#register',
} = Astro.props as Props;
---

<div id="home" class="relative overflow-hidden">
  <div class="hero-shell container mx-auto px-6 py-12 md:py-14 relative z-10">
    <div class="hero-grid flex flex-col items-center text-center">
      <div class="hero-intro max-w-5xl w-full">
        <h1 class="sr-only">{title}</h1>

        <div class="hero-title-stage" data-hero-hover>
          <svg width="100%" height="100%" viewBox="0 0 1600 360" xmlns="http://www.w3.org/2000/svg" class="hero-title-svg" role="img" aria-label={title}>
            <defs>
              <linearGradient id="heroFillGradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#fffdfd" />
                <stop offset="55%" stop-color="#ffece7" />
                <stop offset="100%" stop-color="#ffcfc4" />
              </linearGradient>
              <clipPath id="heroTitleClip">
                <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" class="hero-title-text">{title}</text>
              </clipPath>
            </defs>

            <g clip-path="url(#heroTitleClip)" class="hero-fluid-layer">
              <g class="hero-fluid-rise">
                <path class="hero-fluid-wave hero-fluid-wave-back" d="M0 60 Q80 24 160 60 T320 60 T480 60 T640 60 T800 60 T960 60 T1120 60 T1280 60 T1440 60 T1600 60 T1760 60 T1920 60 T2080 60 T2240 60 T2400 60 T2560 60 T2720 60 T2880 60 T3040 60 T3200 60 V360 H0 Z" />
                <path class="hero-fluid-wave hero-fluid-wave-front" d="M0 60 Q80 24 160 60 T320 60 T480 60 T640 60 T800 60 T960 60 T1120 60 T1280 60 T1440 60 T1600 60 T1760 60 T1920 60 T2080 60 T2240 60 T2400 60 T2560 60 T2720 60 T2880 60 T3040 60 T3200 60 V360 H0 Z" />
              </g>
            </g>

            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" class="hero-title-text hero-hover-outline">{title}</text>
          </svg>
        </div>

        <p class="hero-copy text-gray-300 text-lg md:text-xl mt-1 mb-6 max-w-3xl mx-auto font-inter font-light tracking-normal leading-relaxed">
          {description}
        </p>

        <div class="hero-actions flex flex-col sm:flex-row gap-4 justify-center">
          <a href={primaryHref} class="hero-action stroke-button stroke-button-strong">
            <iconify-icon icon="solar:rocket-linear" width="20" height="20"></iconify-icon>
            {primaryAction}
          </a>
          <a href={secondaryHref} class="hero-action stroke-button stroke-button-muted">
            <iconify-icon icon="solar:play-circle-linear" width="20" height="20"></iconify-icon>
            {secondaryAction}
          </a>
        </div>
      </div>
    </div>

    <div class="hero-divider h-px glass-divider mt-10 opacity-50"></div>
  </div>
</div>

<style>
  .hero-shell {
    min-height: calc(100vh - 7.5rem);
    display: flex;
    align-items: center;
    padding-top: 0;
    padding-bottom: 5rem;
  }

  .hero-grid {
    width: 100%;
  }

  .hero-title-stage {
    width: min(100%, 1600px);
    margin: 0 auto;
    height: clamp(128px, 20vw, 260px);
    position: relative;
  }

  .hero-title-svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-title-text {
    font-family: var(--font-hero);
    font-size: clamp(96px, 12.2vw, 160px);
    font-weight: 400;
    letter-spacing: 0;
  }

  .hero-hover-outline {
    fill: transparent;
    stroke: rgba(255, 240, 240, 0.55);
    stroke-width: 0.8;
    paint-order: stroke fill;
  }

  .hero-fluid-layer {
    filter: drop-shadow(0 0 18px rgba(255, 120, 100, 0.3));
  }

  .hero-fluid-rise {
    transform: translateY(340px);
  }

  .hero-fluid-wave {
    fill: url(#heroFillGradient);
    animation: heroWaveDrift 7s linear infinite;
  }

  .hero-fluid-wave-back {
    opacity: 0.5;
    animation: heroWaveDriftBack 11s linear infinite;
  }

  .hero-copy {
    text-wrap: balance;
  }

  .hero-actions {
    width: 100%;
    flex-wrap: wrap;
  }

  .hero-action {
    min-width: min(100%, 17rem);
  }

  body:not(.loading) .hero-fluid-rise {
    animation: heroFluidCycle 10s cubic-bezier(0.33, 1, 0.68, 1) 0.15s infinite;
  }

  @keyframes heroFluidCycle {
    0% {
      transform: translateY(340px);
    }
    20% {
      transform: translateY(0);
    }
    76% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(340px);
    }
  }

  @keyframes heroWaveDrift {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-640px);
    }
  }

  @keyframes heroWaveDriftBack {
    from {
      transform: translate(-160px, -14px);
    }
    to {
      transform: translate(-800px, -14px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fluid-rise,
    .hero-fluid-wave,
    .hero-fluid-wave-back {
      animation: none;
    }

    .hero-fluid-rise {
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero-shell {
      min-height: calc(100vh - 5rem);
      padding-top: 1.25rem;
      padding-bottom: 3rem;
    }

    .hero-title-stage {
      height: clamp(90px, 28vw, 180px);
    }

    .hero-copy {
      font-size: 1rem;
    }
  }

  @media (max-width: 420px) {
    .hero-title-stage {
      height: clamp(70px, 24vw, 140px);
    }

    .hero-actions {
      gap: 0.75rem;
    }

    .hero-action {
      min-width: 100%;
    }
  }
</style>
