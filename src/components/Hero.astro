<header class="relative min-h-screen w-full flex items-center justify-center overflow-hidden pt-20">
  <div class="absolute top-0 right-0 w-3/4 h-full bg-halftone transform -skew-x-12 translate-x-1/4 z-0 border-l-4 border-black"></div>
  <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-neutral-900 transform skew-y-6 translate-y-20 z-0 border-t-4 border-white"></div>

  <div class="absolute top-1/4 left-0 w-full h-2 bg-white transform -rotate-3 z-0"></div>
  <div class="absolute top-3/4 right-0 w-full h-1 bg-black transform rotate-2 z-0"></div>

  <div class="container mx-auto px-4 relative z-10 grid md:grid-cols-2 gap-12 items-center">
    <div class="flex flex-col items-start space-y-8 animate-enter-left">
      <div class="bg-black text-white px-4 py-1 transform -skew-x-12 border border-white inline-block mb-4 rotate-2 shadow-[4px_4px_0px_#D92323]">
        <span class="font-bold text-sm tracking-widest uppercase transform skew-x-12 inline-block">Where ideas turn into ventures</span>
      </div>

      <div class="relative">
        <h2 class="font-anton text-7xl md:text-9xl uppercase leading-[0.85] text-white text-shadow-hard transform -rotate-2">
          Build.<br />
          <span class="text-black bg-white px-2">Break.</span><br />
          <span class="text-red-600">Scale.</span>
        </h2>
        <div class="absolute -top-12 -right-12 text-yellow-400 animate-pulse-slow hidden md:block">
          <iconify-icon icon="solar:star-fall-bold" width="80"></iconify-icon>
        </div>
      </div>

      <p class="font-marker text-xl md:text-2xl text-gray-200 bg-black/80 p-4 transform rotate-1 max-w-md border-l-4 border-red-600">
        E-Cell VJIT empowers students to innovate, build startups, and create impact.
      </p>

      <div class="pt-4 transform hover:scale-105 transition-transform duration-200">
        <button class="relative group bg-transparent border-none p-0 cursor-pointer">
          <div class="absolute inset-0 bg-black translate-x-2 translate-y-2 clip-slant-right"></div>
          <div class="relative bg-red-600 text-white px-10 py-5 clip-slant-right border-2 border-black group-hover:bg-white group-hover:text-black transition-colors">
            <span class="font-anton text-2xl tracking-wide uppercase flex items-center gap-2">
              Join E-Cell
              <iconify-icon icon="solar:arrow-right-linear" width="24"></iconify-icon>
            </span>
          </div>
        </button>
      </div>
      <div class="pt-4 transform hover:scale-105 transition-transform duration-200">
        <button class="relative group bg-transparent border-none p-0 cursor-pointer">
          <div class="absolute inset-0 bg-black translate-x-2 translate-y-2 clip-slant-right"></div>
          <div class="relative bg-white text-black px-10 py-5 clip-slant-right border-2 border-black group-hover:bg-red-600 group-hover:text-white transition-colors">
            <span class="font-anton text-2xl tracking-wide uppercase flex items-center gap-2">
              Explore Events
              <iconify-icon icon="solar:arrow-right-linear" width="24"></iconify-icon>
            </span>
          </div>
        </button>
      </div>
    </div>

    <div class="relative hidden md:flex items-center justify-center animate-enter-right">
      <div class="relative w-96 h-96 bg-white border-4 border-black transform rotate-3 p-2 box-shadow-hard">
        <div class="absolute -top-6 -left-6 bg-yellow-400 text-black font-anton px-4 py-2 transform -rotate-12 border-2 border-black z-20 shadow-[4px_4px_0px_#fff]">
          JOIN THE MOVEMENT
        </div>

        <div class="w-full h-full bg-black overflow-hidden relative grayscale contrast-125 group hover:grayscale-0 transition-all duration-500">
          <svg class="absolute inset-0 w-full h-full opacity-20" viewBox="0 0 100 100" preserveAspectRatio="none">
            <path d="M0,0 L100,100 M100,0 L0,100" stroke="white" stroke-width="2"></path>
          </svg>

          <div class="absolute inset-0 flex flex-col items-center justify-center text-white">
            <iconify-icon icon="solar:gamepad-charge-linear" width="120" class="mb-4 text-red-600"></iconify-icon>
            <h3 class="font-anton text-4xl uppercase">Build Startup</h3>
          </div>
        </div>
      </div>

      <div class="absolute -bottom-10 -left-12 bg-white text-black p-4 border-2 border-black transform -rotate-6 z-30 max-w-xs">
        <div class="flex items-center gap-3">
          <iconify-icon icon="solar:cup-star-bold" class="text-red-600 text-3xl"></iconify-icon>
          <div>
            <div class="font-anton text-lg uppercase leading-none">Impact Stats</div>
            <div class="font-mono text-xs">Community Active</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
