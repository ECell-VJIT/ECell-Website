---
interface Props {
  badge?: string;
  title?: string;
  description?: string;
  primaryAction?: string;
  secondaryAction?: string;
  primaryHref?: string;
  secondaryHref?: string;
}

const {
  badge = 'E-Cell VJIT 2026',
  title = 'E-CELL VJIT',
  description = 'E-Cell brings together students who want to learn, build, and experiment with real-world problems. Through events, mentorship, and a strong community, it creates opportunities to move from curiosity to execution.',
  primaryAction = 'View Upcoming Events',
  secondaryAction = 'Register for Events',
  primaryHref = '/events',
  secondaryHref = '/events#register',
} = Astro.props as Props;
---

<div id="home" class="relative overflow-hidden">
  <div class="hero-shell container mx-auto px-6 py-16 md:py-20 relative z-10">
    <div class="hero-grid flex flex-col items-center text-center">
      <div class="hero-intro max-w-5xl w-full">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full glass border border-red-500/20 mb-8">
          <span class="flex h-2 w-2 rounded-full bg-red-600 animate-pulse"></span>
          <span class="text-xs font-medium text-red-200 uppercase tracking-wider">{badge}</span>
        </div>

        <h1 class="sr-only">{title}</h1>

        <div class="hero-title-stage" data-hero-hover>
          <svg width="100%" height="100%" viewBox="0 0 1600 360" xmlns="http://www.w3.org/2000/svg" class="hero-title-svg" role="img" aria-label={title}>
            <defs>
              <linearGradient id="heroTextGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#fb7185" />
                <stop offset="50%" stop-color="#ef4444" />
                <stop offset="100%" stop-color="#fb923c" />
              </linearGradient>

              <radialGradient id="heroRevealMaskGradient" cx="50%" cy="50%" r="22%">
                <stop offset="0%" stop-color="white" />
                <stop offset="100%" stop-color="black" />
              </radialGradient>

              <mask id="heroTextMask">
                <rect x="0" y="0" width="1600" height="360" fill="url(#heroRevealMaskGradient)" />
              </mask>
            </defs>

            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" class="hero-hover-outline">{title}</text>
            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" class="hero-hover-stroke">{title}</text>
            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" stroke="url(#heroTextGradient)" mask="url(#heroTextMask)" class="hero-hover-reveal">{title}</text>
          </svg>
        </div>

        <p class="hero-copy text-gray-300 text-lg md:text-xl mt-8 mb-8 max-w-3xl mx-auto font-inter font-light tracking-normal leading-relaxed">
          {description}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={primaryHref} class="bg-gradient-to-r from-red-700 to-orange-600 text-white font-inter font-medium text-base rounded-md px-8 py-4 hover:shadow-[0_0_30px_rgba(220,38,38,0.4)] transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-900/20">
            <iconify-icon icon="solar:rocket-linear" width="20" height="20"></iconify-icon>
            {primaryAction}
          </a>
          <a href={secondaryHref} class="glass font-inter text-base rounded-md px-8 py-4 hover:bg-white/5 transition-all flex items-center justify-center gap-2">
            <iconify-icon icon="solar:play-circle-linear" width="20" height="20"></iconify-icon>
            {secondaryAction}
          </a>
        </div>
      </div>
    </div>

    <div class="hero-divider h-px glass-divider mt-16 opacity-50"></div>
  </div>
</div>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-hero-hover]');
    if (!(root instanceof HTMLElement)) return;

    const svg = root.querySelector('svg');
    const revealGradient = root.querySelector('#heroRevealMaskGradient');
    if (!(svg instanceof SVGSVGElement) || !(revealGradient instanceof SVGRadialGradientElement)) return;

    let targetX = 50;
    let targetY = 50;
    let currentX = 50;
    let currentY = 50;
    let ticking = false;

    const animate = () => {
      currentX += (targetX - currentX) * 0.16;
      currentY += (targetY - currentY) * 0.16;
      revealGradient.setAttribute('cx', `${currentX}%`);
      revealGradient.setAttribute('cy', `${currentY}%`);
      if (Math.abs(targetX - currentX) > 0.02 || Math.abs(targetY - currentY) > 0.02) {
        requestAnimationFrame(animate);
      } else {
        ticking = false;
      }
    };

    const queueAnimation = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(animate);
      }
    };

    const moveMask = (event) => {
      const rect = svg.getBoundingClientRect();
      targetX = ((event.clientX - rect.left) / rect.width) * 100;
      targetY = ((event.clientY - rect.top) / rect.height) * 100;
      queueAnimation();
    };

    root.addEventListener('mousemove', moveMask, { passive: true });
    root.addEventListener('mouseenter', queueAnimation, { passive: true });
    root.addEventListener('mouseleave', () => {
      targetX = 50;
      targetY = 50;
      queueAnimation();
    }, { passive: true });
  })();
</script>

<style>
  .hero-shell {
    min-height: calc(100vh - 6rem);
    display: flex;
    align-items: center;
  }

  .hero-grid {
    width: 100%;
  }

  .hero-title-stage {
    width: min(100%, 1600px);
    margin: 0 auto;
    height: clamp(180px, 28vw, 360px);
    position: relative;
  }

  .hero-title-svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-hover-outline,
  .hero-hover-stroke,
  .hero-hover-reveal {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(120px, 17vw, 210px);
    font-weight: 700;
    fill: transparent;
    letter-spacing: 4px;
  }

  .hero-hover-outline {
    stroke: rgba(255, 226, 226, 0.24);
    stroke-width: 0.5;
  }

  .hero-hover-stroke {
    stroke: rgba(255, 120, 110, 0.92);
    stroke-width: 0.6;
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    animation: heroStrokeDraw 5s ease-in-out infinite alternate;
  }

  .hero-hover-reveal {
    stroke-width: 0.42;
  }

  .hero-copy {
    text-wrap: balance;
  }

  @keyframes heroStrokeDraw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 768px) {
    .hero-shell {
      min-height: auto;
      padding-top: 3rem;
      padding-bottom: 2rem;
    }

    .hero-title-stage {
      height: clamp(130px, 34vw, 220px);
    }
  }
</style>