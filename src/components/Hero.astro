---
interface Props {
  title?: string;
  description?: string;
  primaryAction?: string;
  secondaryAction?: string;
  primaryHref?: string;
  secondaryHref?: string;
}

const {
  title = 'E-CELL VJIT',
  description = 'E-Cell brings together students who want to learn, build, and experiment with real-world problems. Through events, mentorship, and a strong community, it creates opportunities to move from curiosity to execution.',
  primaryAction = 'View Upcoming Events',
  secondaryAction = 'Register for Events',
  primaryHref = '/events',
  secondaryHref = '/events#register',
} = Astro.props as Props;
---

<div id="home" class="relative overflow-hidden">
  <div class="hero-shell container mx-auto px-6 py-12 md:py-14 relative z-10">
    <div class="hero-grid flex flex-col items-center text-center">
      <div class="hero-intro max-w-5xl w-full">
        <h1 class="sr-only">{title}</h1>

        <div class="hero-title-stage" data-hero-hover>
          <svg width="100%" height="100%" viewBox="0 0 1600 360" xmlns="http://www.w3.org/2000/svg" class="hero-title-svg" role="img" aria-label={title}>
            <defs>
              <linearGradient id="heroTextGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#fb7185" />
                <stop offset="50%" stop-color="#ef4444" />
                <stop offset="100%" stop-color="#fb923c" />
              </linearGradient>
            </defs>

            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" class="hero-hover-outline">{title}</text>
            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" class="hero-hover-stroke">{title}</text>
          </svg>
        </div>

        <p class="hero-copy text-gray-300 text-lg md:text-xl mt-1 mb-6 max-w-3xl mx-auto font-inter font-light tracking-normal leading-relaxed">
          {description}
        </p>

        <div class="hero-actions flex flex-col sm:flex-row gap-4 justify-center">
          <a href={primaryHref} class="hero-action stroke-button stroke-button-strong">
            <iconify-icon icon="solar:rocket-linear" width="20" height="20"></iconify-icon>
            {primaryAction}
          </a>
          <a href={secondaryHref} class="hero-action stroke-button stroke-button-muted">
            <iconify-icon icon="solar:play-circle-linear" width="20" height="20"></iconify-icon>
            {secondaryAction}
          </a>
        </div>
      </div>
    </div>

    <div class="hero-divider h-px glass-divider mt-10 opacity-50"></div>
  </div>
</div>

<style>
  .hero-shell {
    min-height: calc(100vh - 7.5rem);
    display: flex;
    align-items: center;
    padding-top: 0;
    padding-bottom: 5rem;
  }

  .hero-grid {
    width: 100%;
  }

  .hero-title-stage {
    width: min(100%, 1600px);
    margin: 0 auto;
    height: clamp(128px, 20vw, 260px);
    position: relative;
  }

  .hero-title-svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-hover-outline,
  .hero-hover-stroke {
    font-family: var(--font-hero);
    font-size: clamp(96px, 12.2vw, 160px);
    font-weight: 400;
    fill: transparent;
    letter-spacing: 0;
    paint-order: stroke fill;
  }

  .hero-hover-outline {
    stroke: rgba(255, 240, 240, 0.52);
    stroke-width: 0.8;
  }

  .hero-hover-stroke {
    stroke: rgba(255, 145, 132, 1);
    stroke-width: 1.2;
    stroke-dasharray: 950;
    stroke-dashoffset: 950;
    filter: drop-shadow(0 0 16px rgba(255, 92, 82, 0.5));
  }

  .hero-copy {
    text-wrap: balance;
  }

  .hero-actions {
    width: 100%;
    flex-wrap: wrap;
  }

  .hero-action {
    min-width: min(100%, 17rem);
  }

  body:not(.loading) .hero-hover-stroke {
    animation: heroStrokeIgnite 4.8s ease-in-out infinite;
  }

  body.loading .hero-hover-stroke {
    animation: none;
    stroke-dashoffset: 950;
    opacity: 0.18;
  }

  @keyframes heroStrokeIgnite {
    0%,
    14% {
      stroke-dashoffset: 950;
      opacity: 0.18;
    }
    38%,
    78% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: 950;
      opacity: 0.18;
    }
  }

  @media (max-width: 768px) {
    .hero-shell {
      min-height: calc(100vh - 5rem);
      padding-top: 1.25rem;
      padding-bottom: 3rem;
    }

    .hero-title-stage {
      height: clamp(118px, 31vw, 205px);
    }
  }
</style>
