---
interface Props {
  badge?: string;
  title?: string;
  description?: string;
  primaryAction?: string;
  secondaryAction?: string;
  primaryHref?: string;
  secondaryHref?: string;
}

const {
  badge = 'E-Cell VJIT 2026',
  title = 'E-CELL VJIT',
  description = 'E-Cell brings together students who want to learn, build, and experiment with real-world problems. Through events, mentorship, and a strong community, it creates opportunities to move from curiosity to execution.',
  primaryAction = 'View Upcoming Events',
  secondaryAction = 'Register for Events',
  primaryHref = '/events',
  secondaryHref = '/events#register',
} = Astro.props as Props;
---

<div id="home" class="relative overflow-hidden">
  <div class="hero-shell container mx-auto px-6 py-12 md:py-14 relative z-10">
    <div class="hero-grid flex flex-col items-center text-center">
      <div class="hero-intro max-w-5xl w-full">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full glass border border-red-500/20 mb-6">
          <span class="flex h-2 w-2 rounded-full bg-red-600 animate-pulse"></span>
          <span class="text-xs font-medium text-red-200 uppercase tracking-wider">{badge}</span>
        </div>

        <h1 class="sr-only">{title}</h1>

        <div class="hero-title-stage" data-hero-hover>
          <svg width="100%" height="100%" viewBox="0 0 1600 360" xmlns="http://www.w3.org/2000/svg" class="hero-title-svg" role="img" aria-label={title}>
            <defs>
              <linearGradient id="heroTextGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#fb7185" />
                <stop offset="50%" stop-color="#ef4444" />
                <stop offset="100%" stop-color="#fb923c" />
              </linearGradient>

              <radialGradient id="heroRevealMaskGradient" cx="50%" cy="42%" r="20%">
                <stop offset="0%" stop-color="white" />
                <stop offset="100%" stop-color="black" />
              </radialGradient>

              <mask id="heroTextMask">
                <rect x="0" y="0" width="1600" height="360" fill="url(#heroRevealMaskGradient)" />
              </mask>
            </defs>

            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" class="hero-hover-outline">{title}</text>
            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" class="hero-hover-stroke">{title}</text>
            <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" stroke="url(#heroTextGradient)" mask="url(#heroTextMask)" class="hero-hover-reveal">{title}</text>
          </svg>
        </div>

        <p class="hero-copy text-gray-300 text-lg md:text-xl mt-5 mb-7 max-w-3xl mx-auto font-inter font-light tracking-normal leading-relaxed">
          {description}
        </p>

        <div class="hero-actions flex flex-col sm:flex-row gap-4 justify-center">
          <a href={primaryHref} class="hero-action hero-action-primary text-white font-inter font-medium text-base rounded-full px-8 py-4 transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-900/20">
            <span class="hero-action-ring" aria-hidden="true"></span>
            <iconify-icon icon="solar:rocket-linear" width="20" height="20"></iconify-icon>
            {primaryAction}
          </a>
          <a href={secondaryHref} class="hero-action hero-action-secondary font-inter text-base rounded-full px-8 py-4 transition-all flex items-center justify-center gap-2">
            <span class="hero-action-ring" aria-hidden="true"></span>
            <iconify-icon icon="solar:play-circle-linear" width="20" height="20"></iconify-icon>
            {secondaryAction}
          </a>
        </div>
      </div>
    </div>

    <div class="hero-divider h-px glass-divider mt-10 opacity-50"></div>
  </div>
</div>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-hero-hover]');
    if (!(root instanceof HTMLElement)) return;

    const svg = root.querySelector('svg');
    const revealGradient = root.querySelector('#heroRevealMaskGradient');
    if (!(svg instanceof SVGSVGElement) || !(revealGradient instanceof SVGRadialGradientElement)) return;

    let targetX = 50;
    let targetY = 42;
    let currentX = 50;
    let currentY = 42;
    let ticking = false;

    const animate = () => {
      currentX += (targetX - currentX) * 0.16;
      currentY += (targetY - currentY) * 0.16;
      revealGradient.setAttribute('cx', `${currentX}%`);
      revealGradient.setAttribute('cy', `${currentY}%`);
      if (Math.abs(targetX - currentX) > 0.02 || Math.abs(targetY - currentY) > 0.02) {
        requestAnimationFrame(animate);
      } else {
        ticking = false;
      }
    };

    const queueAnimation = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(animate);
      }
    };

    const moveMask = (event) => {
      const rect = svg.getBoundingClientRect();
      targetX = ((event.clientX - rect.left) / rect.width) * 100;
      targetY = ((event.clientY - rect.top) / rect.height) * 100;
      queueAnimation();
    };

    root.addEventListener('mousemove', moveMask, { passive: true });
    root.addEventListener('mouseenter', queueAnimation, { passive: true });
    root.addEventListener('mouseleave', () => {
      targetX = 50;
      targetY = 42;
      queueAnimation();
    }, { passive: true });
  })();
</script>

<style>
  .hero-shell {
    min-height: calc(82vh - 6rem);
    display: flex;
    align-items: flex-start;
    padding-top: 1.25rem;
  }

  .hero-grid {
    width: 100%;
  }

  .hero-title-stage {
    width: min(100%, 1600px);
    margin: 0 auto;
    height: clamp(150px, 25vw, 320px);
    position: relative;
    transform: translateY(-0.85rem);
  }

  .hero-title-svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-hover-outline,
  .hero-hover-stroke,
  .hero-hover-reveal {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(126px, 16vw, 205px);
    font-weight: 700;
    fill: transparent;
    letter-spacing: 2px;
    paint-order: stroke fill;
  }

  .hero-hover-outline {
    stroke: rgba(255, 240, 240, 0.52);
    stroke-width: 0.8;
  }

  .hero-hover-stroke {
    stroke: rgba(255, 145, 132, 1);
    stroke-width: 1.2;
    stroke-dasharray: 950;
    stroke-dashoffset: 950;
    filter: drop-shadow(0 0 16px rgba(255, 92, 82, 0.5));
    animation: heroStrokeDraw 5s ease-in-out infinite alternate;
  }

  .hero-hover-reveal {
    stroke-width: 1.1;
    filter: drop-shadow(0 0 18px rgba(255, 107, 90, 0.48));
  }

  .hero-copy {
    text-wrap: balance;
  }

  .hero-actions {
    width: 100%;
    flex-wrap: wrap;
  }

  .hero-action {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-width: min(100%, 17rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 12px 28px rgba(0, 0, 0, 0.22);
  }

  .hero-action::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, rgba(254, 202, 202, 0.7), rgba(239, 68, 68, 0.45), rgba(251, 146, 60, 0.8));
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    opacity: 0.85;
    transition: opacity 180ms ease, filter 180ms ease;
    pointer-events: none;
  }

  .hero-action::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.18) 18%, transparent 36%);
    transform: translateX(-130%);
    transition: transform 520ms ease;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .hero-action:hover::after {
    transform: translateX(130%);
  }

  .hero-action:hover::before {
    opacity: 1;
    filter: drop-shadow(0 0 10px rgba(255, 92, 82, 0.35));
  }

  .hero-action-ring {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
  }

  .hero-action-primary {
    background: linear-gradient(135deg, rgba(185, 28, 28, 0.96), rgba(249, 115, 22, 0.95));
    color: white;
  }

  .hero-action-primary:hover {
    transform: translateY(-1px);
    box-shadow:
      0 0 0 1px rgba(254, 202, 202, 0.12),
      0 16px 32px rgba(220, 38, 38, 0.22),
      0 0 24px rgba(248, 113, 113, 0.18);
  }

  .hero-action-secondary {
    background: rgba(40, 5, 0, 0.28);
    color: rgb(254 226 226);
  }

  .hero-action-secondary:hover {
    transform: translateY(-1px);
    background: rgba(40, 5, 0, 0.4);
    box-shadow:
      0 0 0 1px rgba(254, 202, 202, 0.14),
      0 12px 28px rgba(0, 0, 0, 0.26),
      0 0 18px rgba(248, 113, 113, 0.12);
  }

  @keyframes heroStrokeDraw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 768px) {
    .hero-shell {
      min-height: auto;
      padding-top: 1.25rem;
      padding-bottom: 2rem;
    }

    .hero-title-stage {
      height: clamp(118px, 31vw, 205px);
      transform: translateY(-0.5rem);
    }
  }
</style>