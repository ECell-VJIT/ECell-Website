---
interface TeamMember {
  name: string;
  role: string;
}

interface Props {
  members?: TeamMember[];
}

const { members = [] } = Astro.props as Props;
---

<section class="container mx-auto px-6 py-16 md:py-24 relative z-10">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {members.map((member) => (
      <div class="glass rounded-lg p-6">
        <h3 class="text-xl font-jakarta font-semibold mb-1">{member.name}</h3>
        <p class="text-gray-300 font-inter">{member.role}</p>
      </div>
    ))}
  </div>
  <slot />
</section>