---
import teamData from '../../team.json';
import TeamCard from './TeamCard.astro';

const members = teamData.core.slice(0, 4);
---

<section id="team" class="container mx-auto px-6 py-16 md:py-24 relative z-10">
  <div class="max-w-3xl mb-10">
    <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">Core Leadership</p>
    <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">The leadership behind E-Cell VJIT</h2>
    <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">Meet the students driving entrepreneurship programs, campus innovation, and community growth across the cell.</p>
  </div>
  <div class="team-grid-optimized grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {members.map((member, index) => (
      <TeamCard
        name={member.name}
        role={member.role}
        image={member.image}
        branch={member.branch}
        year={member.year}
        tagline={member.tagline}
        socials={member.socials}
        index={index}
      />
    ))}
  </div>
  <div class="mt-8">
    <a href="/team" class="inline-flex items-center gap-2 text-sm font-inter glass rounded-md px-4 py-2 hover:bg-red-900/20 hover:border-red-500/30 text-gray-200 transition-all">
      View Full Team
      <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
    </a>
  </div>
  <slot />
</section>