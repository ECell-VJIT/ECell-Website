---
interface EventItem {
  title: string;
  description: string;
}

interface Props {
  events?: EventItem[];
}

const { events = [] } = Astro.props as Props;
---

<section class="container mx-auto px-6 py-16 md:py-24 relative z-10">
  <div class="grid gap-4 md:gap-6">
    {events.map((event) => (
      <article class="glass rounded-lg p-6">
        <h3 class="text-xl font-jakarta font-semibold mb-2">{event.title}</h3>
        <p class="text-gray-300 font-inter leading-relaxed">{event.description}</p>
      </article>
    ))}
  </div>
  <slot />
</section>