---
interface EventItem {
  title: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  events?: EventItem[];
}

const {
  eyebrow = 'Traction',
  title = 'What we\'ve built and achieved so far.',
  description = 'From campus sessions to collaborative outcomes, these are the milestones that keep E-Cell moving forward.',
  events = [
  {
    title: 'Events conducted',
    description: 'Multiple workshops, hackathons, and sessions that brought students together around entrepreneurship.'
  },
  {
    title: 'Participation numbers',
    description: 'Active involvement from students across domains, teams, and interest groups.'
  },
  {
    title: 'Achievements',
    description: 'Recognitions, successful projects, and outcomes that reflect the momentum being built.'
  },
  {
    title: 'Impact',
    description: 'Ideas initiated, skills developed, and collaborations formed across the campus community.'
  }
] } = Astro.props as Props;
---

<section id="traction" class="container mx-auto px-6 py-16 md:py-24 relative z-10">
  <div class="max-w-3xl mb-10">
    <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">{eyebrow}</p>
    <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">{title}</h2>
    <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">{description}</p>
  </div>
  <div class="grid gap-4 md:gap-6">
    {events.map((event) => (
      <article class="glass rounded-lg p-6">
        <h3 class="text-xl font-jakarta font-semibold mb-2">{event.title}</h3>
        <p class="text-gray-300 font-inter leading-relaxed">{event.description}</p>
      </article>
    ))}
  </div>
  <slot />
</section>