---
interface DomainItem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  domains?: DomainItem[];
}

const { domains = [
  {
    icon: 'solar:rocket-2-linear',
    title: 'Workshops',
    description: 'Hands-on sessions on startups, technology, problem-solving, and practical execution skills.'
  },
  {
    icon: 'solar:code-square-linear',
    title: 'Hackathons',
    description: 'Build and test ideas under real constraints while collaborating with peers to ship fast.'
  },
  {
    icon: 'solar:notebook-linear',
    title: 'Mentorships',
    description: 'Guidance from experienced founders, alumni, and professionals who help shape ideas into outcomes.'
  },
  {
    icon: 'solar:microphone-3-linear',
    title: 'Programs',
    description: 'Structured initiatives that help students move from concept to execution through a clear roadmap.'
  }
] } = Astro.props as Props;
---

<section id="domains" class="container mx-auto px-6 py-16 md:py-24 relative z-10">
  <div class="max-w-3xl mb-10">
    <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">Opportunities</p>
    <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">Ways to learn, build and grow</h2>
    <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">Hands-on opportunities that help students move from curiosity to execution and turn ideas into action.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    {domains.map((domain) => (
      <article class="glass rounded-lg p-6 group hover:border-red-500/30 transition-colors">
        <div class="mb-4 text-red-400">
          <iconify-icon icon={domain.icon} width="30" height="30"></iconify-icon>
        </div>
        <h3 class="text-xl font-jakarta font-semibold mb-2">{domain.title}</h3>
        <p class="text-gray-300 font-inter leading-relaxed">{domain.description}</p>
      </article>
    ))}
  </div>
</section>