---
interface StatItem {
  icon: string;
  value: string;
  label: string;
}

interface Props {
  stats?: StatItem[];
}

const {
  stats = [
    { icon: 'solar:lightbulb-minimalistic-linear', value: '40+', label: 'Startup Ideas Incubated' },
    { icon: 'solar:calendar-linear', value: '18+', label: 'Campus Initiatives' },
    { icon: 'solar:users-group-rounded-linear', value: '600+', label: 'Student Participants' },
    { icon: 'solar:cup-star-linear', value: '12+', label: 'Innovation Workshops' },
  ],
} = Astro.props as Props;
---

<div class="container mx-auto px-6 pb-16 md:pb-24 relative z-10">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
    {stats.map((stat) => (
      <div class="glass rounded-lg p-6 text-center group hover:border-red-500/30 transition-colors">
        <div class="mb-3 flex justify-center text-red-400">
          <iconify-icon icon={stat.icon} width="32" height="32"></iconify-icon>
        </div>
        <p class="text-3xl font-jakarta font-semibold mb-1 tracking-tight text-white">{stat.value}</p>
        <p class="text-gray-400 font-inter text-sm font-light">{stat.label}</p>
      </div>
    ))}
  </div>
</div>