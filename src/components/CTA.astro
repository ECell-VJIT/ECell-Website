---
interface Props {
  title?: string;
  description?: string;
  actionLabel?: string;
}

const {
  title = 'Ready for the next step',
  description = 'Future CTA content can be injected through props or data sources without changing the layout contract.',
  actionLabel = 'Get Started',
} = Astro.props as Props;
---

<section class="container mx-auto px-6 py-16 md:py-24 relative z-10">
  <div class="glass rounded-2xl p-8 md:p-12 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
    <div class="max-w-2xl">
      <h2 class="text-3xl md:text-5xl font-jakarta font-semibold tracking-tight mb-4">{title}</h2>
      <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">{description}</p>
    </div>
    <button class="bg-gradient-to-r from-red-700 to-orange-600 text-white font-inter font-medium text-base rounded-md px-8 py-4 hover:shadow-[0_0_30px_rgba(220,38,38,0.4)] transition-all shadow-lg shadow-red-900/20">
      {actionLabel}
    </button>
  </div>
</section>