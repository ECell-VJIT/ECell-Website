---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackgroundShader from '../../components/BackgroundShader.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import TeamCard from '../../components/TeamCard.astro';
import teamData from '../../../team.json';

const administration = teamData.administration ?? [];
const core = teamData.core;
const president = core.find((member) => member.role.toLowerCase() === 'president');
const associatePresident = core.find((member) => member.role.toLowerCase() === 'associate president');
const topLeadership = [president, associatePresident].filter(Boolean);
const leadIds = new Set(topLeadership.map((member) => member.id));
const otherLeads = core.filter((member) => !leadIds.has(member.id));

const teamLinks = [
  { label: 'Tech', href: '/team/tech' },
  { label: 'Digital', href: '/team/digital' },
  { label: 'Creative', href: '/team/creative' },
  { label: 'HR and Documentation', href: '/team/documentation' },
  { label: 'Marketing', href: '/team/marketing' },
  { label: 'Event Management', href: '/team/event-management' }
];
---

<BaseLayout title="E-Cell VJIT | Core Team">
  <BackgroundShader />
  <Navbar />

  <section class="container mx-auto px-6 py-16 md:py-24 relative z-10">
    <div class="max-w-3xl mb-10 md:mb-12">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">Core Team</p>
      <h1 class="text-4xl md:text-6xl font-jakarta font-semibold tracking-tight mb-4">The leadership behind E-Cell VJIT</h1>
      <p class="text-gray-300 font-inter text-base md:text-lg leading-relaxed">
        Meet the core team driving entrepreneurship programs, campus innovation, and community growth.
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-3 mb-8 md:mb-10">
      <span class="glass rounded-full px-4 py-2 text-xs uppercase tracking-[0.2em] text-red-200/90">Core Members {core.length}</span>
      <span class="glass rounded-full px-4 py-2 text-xs uppercase tracking-[0.2em] text-red-200/90">Domain Leads {otherLeads.length}</span>
    </div>

    <div class="glass noise-overlay rounded-2xl p-6 md:p-8 mb-8 md:mb-10">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">Institutional Leadership</p>
      <div class="team-grid-optimized grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-7">
        {administration.map((member, index) => (
          <TeamCard
            name={member.name}
            role={member.role}
            image={member.image}
            branch={member.branch}
            year={member.year}
            tagline={member.tagline}
            socials={member.socials}
            index={index}
          />
        ))}
      </div>
    </div>

    <div class="fire-line-divider" aria-hidden="true"></div>

    <div class="glass noise-overlay rounded-2xl p-6 md:p-8 mb-8 md:mb-10">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4 text-center">Core Leadership</p>
      <div class="leadership-lane md:hidden">
        {topLeadership.map((member, index) => (
          <div>
            <TeamCard
              name={member.name}
              role={member.role}
              image={member.image}
              branch={member.branch}
              year={member.year}
              tagline={member.tagline}
              socials={member.socials}
              index={index}
            />
          </div>
        ))}
      </div>
      <div class="team-grid-optimized hidden md:grid max-w-4xl mx-auto grid-cols-1 md:grid-cols-2 gap-6 md:gap-7 place-items-center">
        {topLeadership.map((member, index) => (
          <div class="w-full max-w-sm">
            <TeamCard
              name={member.name}
              role={member.role}
              image={member.image}
              branch={member.branch}
              year={member.year}
              tagline={member.tagline}
              socials={member.socials}
              index={index}
            />
          </div>
        ))}
      </div>
    </div>

    <div class="fire-line-divider" aria-hidden="true"></div>

    <div class="glass noise-overlay rounded-2xl p-6 md:p-8">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">Domain Leads</p>
      <div class="team-grid-optimized grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-7">
        {otherLeads.map((member, index) => (
          <TeamCard
            name={member.name}
            role={member.role}
            image={member.image}
            branch={member.branch}
            year={member.year}
            tagline={member.tagline}
            socials={member.socials}
            index={index}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="container mx-auto px-6 pb-16 md:pb-24 relative z-10">
    <div class="fire-line-divider" aria-hidden="true"></div>
    <div class="glass noise-overlay rounded-2xl p-8 md:p-10">
      <p class="text-xs uppercase tracking-[0.3em] text-red-200/80 mb-4">Explore Teams</p>
      <h2 class="text-2xl md:text-4xl font-jakarta font-semibold tracking-tight mb-6">Browse members by domain</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {teamLinks.map((teamLink) => (
          <a href={teamLink.href} class="glass rounded-lg px-5 py-4 font-inter text-gray-200 hover:text-white hover:border-red-500/30 transition-all">
            {teamLink.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>